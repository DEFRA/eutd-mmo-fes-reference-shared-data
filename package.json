{
  "name": "mmo-shared-reference-data",
  "version": "1.4.0-beta.0",
  "description": "Shared repo which holds common code of reference data reader and batch data repo",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "cross-env JEST_JUNIT_OUTPUT_DIR=test-results JEST_JUNIT_OUTPUT_NAME=test-results.xml NODE_ENV=test jest test/ --coverage --ci",
    "test:ci": "cross-env JEST_JUNIT_OUTPUT_DIR=test-results JEST_JUNIT_OUTPUT_NAME=junit.xml NODE_ENV=test jest --runInBand --watchAll=false --reporters=default --reporters=jest-junit --coverage --ci",
    "test:watch": "cross-env JEST_JUNIT_OUTPUT_DIR=test-results JEST_JUNIT_OUTPUT_NAME=test-results.xml NODE_ENV=test jest --runInBand test/ --coverage --ci --watch",
    "lint": "eslint . --ext .ts"
  },
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "~24.13.1",
    "npm": "~11.8.0"
  },
  "devDependencies": {
    "@types/bunyan": "^1.8.11",
    "@types/csvtojson": "2.0.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "6.18.1",
    "@typescript-eslint/parser": "6.18.1",
    "babel-jest": "29.7.0",
    "eslint": "8.57.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-plugin-jest": "27.9.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "9.0.11",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.8.3",
    "sinon": "17.0.1",
    "ts-jest": "^29.4.9",
    "tsup": "8.5.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/service-bus": "^7.9.4",
    "ajv": "^6.15.0",
    "axios": "^1.15.2",
    "bunyan": "1.8.15",
    "cross-env": "7.0.3",
    "csvtojson": "^2.0.14",
    "dotenv": "16.4.5",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "uuid": "^9.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest",
      "^.+\\.ts?$": "ts-jest"
    },
    "moduleFileExtensions": [
      "tsx",
      "ts",
      "js",
      "json"
    ],
    "testRegex": "/test/.*\\.(tsx|ts|js)$",
    "testPathIgnorePatterns": [
      "/test/mockData.js"
    ],
    "collectCoverage": true,
    "coverageReporters": [
      "clover",
      "json",
      "lcov",
      "text",
      "cobertura"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    }
  },
  "prettier": {
    "singleQuote": true
  }
}
